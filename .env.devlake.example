# =============================================================================
# DevLake Stack — Variáveis de Ambiente
# Copiar para .env.devlake e preencher os valores
# NUNCA commitar .env.devlake com valores reais
# =============================================================================

# MySQL DevLake
DEVLAKE_MYSQL_ROOT_PASSWORD=devlake_root
DEVLAKE_MYSQL_PASSWORD=devlake
DEVLAKE_DB_URL=mysql://merico:devlake@devlake-mysql:3306/lake?charset=utf8mb4&parseTime=True&loc=UTC

# DevLake API
DEVLAKE_ENCRYPTION_SECRET=pandora-devlake-secret-change-in-prod

# Grafana
GF_SECURITY_ADMIN_PASSWORD=pandora-grafana

# GitHub (necessário para T-01-6: configurar GitHub connector)
# Criar em: https://github.com/settings/tokens
# Scopes necessários: repo, read:user
GITHUB_TOKEN=ghp_seu_token_aqui
GITHUB_REPO_OWNER=qweralfredo
GITHUB_REPO_NAME=agentic-task-system
