# =============================================================================
# DevLake Stack — Variáveis de Ambiente
# Copiar para .env.devlake e preencher os valores
# NUNCA commitar .env.devlake com valores reais
# =============================================================================

# MySQL DevLake
DEVLAKE_MYSQL_ROOT_PASSWORD=devlake_root
DEVLAKE_MYSQL_PASSWORD=devlake

# Lake plugin dir, absolute path or relative path
PLUGIN_DIR=bin/plugins
REMOTE_PLUGIN_DIR=python/plugins

# Lake Database Connection String (Lido diretamente pelo container do Devlake)
DB_URL=mysql://merico:devlake@devlake-mysql:3306/lake?charset=utf8mb4&parseTime=True&loc=UTC
E2E_DB_URL=mysql://merico:devlake@devlake-mysql:3306/lake_test?charset=utf8mb4&parseTime=True&loc=UTC

# Silent Error Warn Info
DB_LOGGING_LEVEL=Error

# Lake REST API
PORT=8080
MODE=release
API_TIMEOUT=120s
API_RETRY=3
API_REQUESTS_PER_HOUR=10000
PIPELINE_MAX_PARALLEL=1

# Debug Info Warn Error
LOGGING_LEVEL=Info
LOGGING_DIR=./logs
ENABLE_STACKTRACE=true
FORCE_MIGRATION=false

# Sensitive information encryption key
ENCRYPTION_SECRET=pandora-devlake-secret-change-in-prod

IN_SECURE_SKIP_VERIFY=
USE_GO_GIT_IN_GIT_EXTRACTOR=false

# Exposto explicitamente para o devlake-config-ui sem o prefixo http://
DEVLAKE_ENDPOINT=devlake:8080
GRAFANA_ENDPOINT=grafana:3000

# Grafana
GF_SECURITY_ADMIN_PASSWORD=pandora-grafana
GF_SERVER_ROOT_URL=http://localhost:3002
GF_USERS_DEFAULT_THEME=light
MYSQL_URL=devlake-mysql:3306
MYSQL_DATABASE=lake
MYSQL_USER=merico
MYSQL_PASSWORD=devlake
TZ=UTC

# GitHub (necessário para scripts de setup)
GITHUB_TOKEN=ghp_seu_token_aqui
GITHUB_REPO_OWNER=qweralfredo
GITHUB_REPO_NAME=agentic-task-system
