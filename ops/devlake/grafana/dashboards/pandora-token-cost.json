{
  "__inputs": [{"name": "DS_DEVLAKE", "label": "DevLake", "type": "datasource", "pluginId": "mysql"}],
  "description": "Pandora Token & Cost Analytics — model usage, cost trends, efficiency metrics",
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "query": "SELECT DISTINCT model_name FROM pandora_agent_runs WHERE model_name != '' ORDER BY model_name",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "blue", "value": null}]},
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Total Cost (30d)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT SUM(cost_usd) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) AND model_name REGEXP '${model}'",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "purple", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Total Tokens (30d)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT SUM(tokens_input + tokens_output) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) AND model_name REGEXP '${model}'",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.20}
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Avg Cost per Run",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(cost_usd) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) AND model_name REGEXP '${model}'",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5000},
              {"color": "red", "value": 20000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Avg Tokens per Run",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(tokens_input + tokens_output) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) AND model_name REGEXP '${model}'",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "currencyUSD"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Daily Cost by Model",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(created_at) AS time, model_name, SUM(cost_usd) AS daily_cost FROM pandora_agent_runs WHERE $__timeFilter(created_at) AND model_name REGEXP '${model}' GROUP BY DATE(created_at), model_name ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Token Usage Over Time (Input vs Output)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(created_at) AS time, SUM(tokens_input) AS input_tokens, SUM(tokens_output) AS output_tokens, SUM(tokens_input + tokens_output) AS total_tokens FROM pandora_agent_runs WHERE $__timeFilter(created_at) AND model_name REGEXP '${model}' GROUP BY DATE(created_at) ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "total_cost"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}]},
          {"matcher": {"id": "byName", "options": "avg_latency_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "success_rate"}, "properties": [{"id": "unit", "value": "percent"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 7,
      "options": {"showHeader": true},
      "title": "Model Cost Efficiency Leaderboard",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT model_name, COUNT(*) AS total_runs, ROUND(SUM(cost_usd), 4) AS total_cost, ROUND(AVG(cost_usd), 6) AS avg_cost_per_run, ROUND(AVG(tokens_input + tokens_output), 0) AS avg_tokens, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, ROUND(SUM(CASE WHEN success = 1 THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0), 1) AS success_rate FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY model_name ORDER BY total_cost DESC",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["pandora", "tokens", "cost", "devlake"],
  "time": {"from": "now-30d", "to": "now"},
  "title": "Pandora — Token & Cost Analytics",
  "uid": "pandora-token-cost",
  "version": 1
}
