{
  "__inputs": [{"name": "DS_DEVLAKE", "label": "DevLake", "type": "datasource", "pluginId": "mysql"}],
  "description": "Pandora DORA Metrics — Deployment Frequency, Lead Time, MTTR, Change Failure Rate",
  "editable": true,
  "panels": [
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 3}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Deployment Frequency (deploys/week)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT COUNT(*) / DATEDIFF(NOW(), DATE_SUB(NOW(), INTERVAL 30 DAY)) * 7 AS value FROM cicd_pipelines WHERE result = 'SUCCESS' AND finished_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 120},
              {"color": "red", "value": 720}
            ]
          },
          "unit": "m"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Lead Time for Changes (avg min)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(TIMESTAMPDIFF(MINUTE, pr.created_date, pr.merged_date)) AS value FROM pull_requests pr WHERE pr.merged_date IS NOT NULL AND pr.merged_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 240}
            ]
          },
          "unit": "m"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["mean"]}},
      "title": "MTTR — Mean Time to Restore (min)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(TIMESTAMPDIFF(MINUTE, i.created_date, i.resolution_date)) AS value FROM issues i WHERE i.type = 'INCIDENT' AND i.resolution_date IS NOT NULL AND i.resolution_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 15}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Change Failure Rate (%)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT ROUND(SUM(CASE WHEN result = 'FAILURE' THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0), 1) AS value FROM cicd_pipelines WHERE finished_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Deployment Frequency Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(finished_date) AS time, COUNT(*) AS deployments, SUM(CASE WHEN result = 'SUCCESS' THEN 1 ELSE 0 END) AS success, SUM(CASE WHEN result = 'FAILURE' THEN 1 ELSE 0 END) AS failures FROM cicd_pipelines WHERE $__timeFilter(finished_date) GROUP BY DATE(finished_date) ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "m"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Lead Time Trend (7-day rolling avg)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(merged_date) AS time, AVG(TIMESTAMPDIFF(MINUTE, created_date, merged_date)) AS lead_time_min FROM pull_requests WHERE merged_date IS NOT NULL AND $__timeFilter(merged_date) GROUP BY DATE(merged_date) ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "success_rate"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 85}, {"color": "green", "value": 95}]}}]},
          {"matcher": {"id": "byName", "options": "avg_lead_time_min"}, "properties": [{"id": "unit", "value": "m"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 7,
      "options": {"showHeader": true},
      "title": "Pipeline Performance by Repository",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT repo_url, COUNT(*) AS total_runs, ROUND(SUM(CASE WHEN result = 'SUCCESS' THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0), 1) AS success_rate, ROUND(AVG(TIMESTAMPDIFF(SECOND, started_date, finished_date) / 60), 1) AS avg_duration_min FROM cicd_pipelines WHERE finished_date >= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY repo_url ORDER BY total_runs DESC LIMIT 20",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["pandora", "dora", "devlake", "engineering-metrics"],
  "time": {"from": "now-30d", "to": "now"},
  "title": "Pandora — DORA Engineering Metrics",
  "uid": "pandora-dora-metrics",
  "version": 1
}
