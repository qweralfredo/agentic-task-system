{
  "__inputs": [{"name": "DS_DEVLAKE_MYSQL", "type": "datasource", "pluginId": "mysql", "description": "DevLake MySQL datasource"}],
  "__requires": [
    {"type": "datasource", "id": "mysql", "name": "MySQL", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "Code Quality & Review Metrics — PR cycle time, code churn, review efficiency via DevLake + GitHub",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 24}, {"color": "red", "value": 72}]},
          "unit": "h",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Avg PR Review Time",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT ROUND(AVG(TIMESTAMPDIFF(HOUR, created_date, merged_date)), 1) AS value FROM pull_requests WHERE merged_date IS NOT NULL AND created_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 6}]},
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Avg Review Cycles",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT ROUND(AVG(review_rounds), 1) AS value FROM pull_requests WHERE created_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 500}]},
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Avg Lines Changed / PR",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT ROUND(AVG(additions + deletions), 0) AS value FROM pull_requests WHERE created_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]},
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Stale PRs (>7 days open)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT COUNT(*) AS value FROM pull_requests WHERE status = 'OPEN' AND created_date < DATE_SUB(NOW(), INTERVAL 7 DAY)",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "h"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "PR Lead Time Trend (daily avg)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT DATE(merged_date) AS time, ROUND(AVG(TIMESTAMPDIFF(HOUR, created_date, merged_date)), 1) AS `Avg Lead Time (h)` FROM pull_requests WHERE merged_date IS NOT NULL AND merged_date >= DATE_SUB(NOW(), INTERVAL $__range_s SECOND) GROUP BY DATE(merged_date) ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Code Churn (Additions vs Deletions)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(merged_date) AS time, SUM(additions) AS `Lines Added` FROM pull_requests WHERE merged_date IS NOT NULL AND merged_date >= DATE_SUB(NOW(), INTERVAL $__range_s SECOND) GROUP BY DATE(merged_date) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(merged_date) AS time, SUM(deletions) AS `Lines Deleted` FROM pull_requests WHERE merged_date IS NOT NULL AND merged_date >= DATE_SUB(NOW(), INTERVAL $__range_s SECOND) GROUP BY DATE(merged_date) ORDER BY time",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Avg Lead Time (h)"}, "properties": [{"id": "unit", "value": "h"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 24}, {"color": "red", "value": 72}]}}, {"id": "custom.displayMode", "value": "color-background"}]},
          {"matcher": {"id": "byName", "options": "Review Cycles"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 6}]}}, {"id": "custom.displayMode", "value": "color-background"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 7,
      "options": {"footer": {"show": false}, "showHeader": true, "sortBy": [{"desc": true, "displayName": "PRs Merged"}]},
      "title": "PR Review Efficiency by Author (Last 30 Days)",
      "type": "table",
      "targets": [{
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "rawSql": "SELECT author_name AS `Author`, COUNT(*) AS `PRs Merged`, ROUND(AVG(TIMESTAMPDIFF(HOUR, created_date, merged_date)), 1) AS `Avg Lead Time (h)`, ROUND(AVG(review_rounds), 1) AS `Review Cycles`, ROUND(AVG(additions + deletions), 0) AS `Avg Lines Changed`, SUM(CASE WHEN TIMESTAMPDIFF(HOUR, created_date, merged_date) > 72 THEN 1 ELSE 0 END) AS `Slow PRs (>72h)` FROM pull_requests WHERE merged_date IS NOT NULL AND merged_date >= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY author_name ORDER BY COUNT(*) DESC LIMIT 20",
        "format": "table",
        "refId": "A"
      }]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["pandora", "code-quality", "devlake", "github"],
  "templating": {
    "list": [
      {
        "current": {},
