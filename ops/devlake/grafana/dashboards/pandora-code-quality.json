        "multi": false,
        "name": "repo",
        "options": [],
        "query": "SELECT DISTINCT repo_url FROM pull_requests ORDER BY repo_url",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Repository"
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Pandora — Code Quality & Review",
  "uid": "pandora-code-quality",
  "version": 1
}
