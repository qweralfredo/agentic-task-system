{
  "__inputs": [{"name": "DS_DEVLAKE_MYSQL", "type": "datasource", "pluginId": "mysql", "description": "DevLake MySQL datasource"}],
  "__requires": [
    {"type": "datasource", "id": "mysql", "name": "MySQL", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "ML Model Performance Tracking — latency p50/p95/p99, success rates, drift detection, model leaderboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 2000}]}, "unit": "ms", "mappings": []}
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Avg Latency (All Models)",
      "type": "stat",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT ROUND(AVG(latency_ms), 0) AS value FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL 7 DAY)", "format": "time_series", "refId": "A"}]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]}, "unit": "percent", "mappings": []}
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Success Rate (7d)",
      "type": "stat",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT ROUND(SUM(success_count) / SUM(run_count) * 100, 1) AS value FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL 7 DAY)", "format": "time_series", "refId": "A"}]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 15}, {"color": "red", "value": 30}]}, "unit": "percent", "mappings": []}
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Max Latency Drift (7d)",
      "type": "stat",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT ROUND(MAX(ABS((recent.avg_latency - baseline.avg_latency) / NULLIF(baseline.avg_latency, 0) * 100)), 1) AS value FROM (SELECT model_name, AVG(avg_latency_ms) AS avg_latency FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL 3 DAY) GROUP BY model_name) recent JOIN (SELECT model_name, AVG(avg_latency_ms) AS avg_latency FROM pandora_agent_run_metrics WHERE run_date BETWEEN DATE_SUB(NOW(), INTERVAL 7 DAY) AND DATE_SUB(NOW(), INTERVAL 3 DAY) GROUP BY model_name) baseline ON recent.model_name = baseline.model_name", "format": "time_series", "refId": "A"}]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 4,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Latency Trend by Model (daily avg)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT run_date AS time, model_name AS metric, ROUND(avg_latency_ms, 0) AS value FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL $__range_s SECOND) ORDER BY run_date, model_name", "format": "time_series", "refId": "A"}]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 5,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Success Rate by Model (daily)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT run_date AS time, model_name AS metric, ROUND(success_count / run_count, 4) AS value FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL $__range_s SECOND) AND run_count > 0 ORDER BY run_date, model_name", "format": "time_series", "refId": "A"}]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Avg Latency (ms)"}, "properties": [{"id": "unit", "value": "ms"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 2000}]}}, {"id": "custom.displayMode", "value": "color-background"}]},
          {"matcher": {"id": "byName", "options": "Success Rate"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]}}, {"id": "custom.displayMode", "value": "color-background"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 6,
      "options": {"footer": {"show": false}, "showHeader": true, "sortBy": [{"desc": false, "displayName": "Avg Latency (ms)"}]},
      "title": "ML Model Leaderboard (Last 7 Days)",
      "type": "table",
      "targets": [{"datasource": {"type": "mysql", "uid": "devlake-mysql-ds"}, "rawSql": "SELECT model_name AS `Model`, SUM(run_count) AS `Total Runs`, ROUND(SUM(success_count) / SUM(run_count) * 100, 1) AS `Success Rate`, ROUND(AVG(avg_latency_ms), 0) AS `Avg Latency (ms)`, ROUND(SUM(total_tokens) / 1000000, 2) AS `Total Tokens (M)`, ROUND(SUM(total_cost_usd), 4) AS `Total Cost (USD)` FROM pandora_agent_run_metrics WHERE run_date >= DATE_SUB(NOW(), INTERVAL 7 DAY) GROUP BY model_name ORDER BY AVG(avg_latency_ms) ASC", "format": "table", "refId": "A"}]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["pandora", "ml-performance", "devlake"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Pandora — ML Model Performance",
  "uid": "pandora-ml-performance",
  "version": 1
}
