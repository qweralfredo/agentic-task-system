{
  "__inputs": [
    {
      "name": "DS_DEVLAKE",
      "label": "DevLake",
      "description": "DevLake MySQL datasource",
      "type": "datasource",
      "pluginId": "mysql",
      "pluginName": "MySQL"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "mysql", "name": "MySQL", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Pandora AI Development Overview — agent runs, token usage, success rate, cost efficiency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "green", "value": 90}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Agent Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT 100.0 * SUM(CASE WHEN success = 1 THEN 1 ELSE 0 END) / COUNT(*) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Total Agent Runs (30d)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT COUNT(*) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.10},
              {"color": "red", "value": 0.50}
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Avg Cost per Run",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(cost_usd) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Avg Latency (30d)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT AVG(latency_ms) AS value FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "tokens_input"}, "properties": [{"id": "displayName", "value": "Input Tokens"}, {"id": "color", "value": {"fixedColor": "#5794F2", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "tokens_output"}, "properties": [{"id": "displayName", "value": "Output Tokens"}, {"id": "color", "value": {"fixedColor": "#8B5CF6", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(created_at) AS time, SUM(tokens_input) AS tokens_input, SUM(tokens_output) AS tokens_output FROM pandora_agent_runs WHERE $__timeFilter(created_at) GROUP BY DATE(created_at) ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "currencyUSD"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Daily Cost by Model",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT DATE(created_at) AS time, model_used AS metric, SUM(cost_usd) AS value FROM pandora_agent_runs WHERE $__timeFilter(created_at) GROUP BY DATE(created_at), model_used ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "success_rate"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 75}, {"color": "green", "value": 90}]}}]},
          {"matcher": {"id": "byName", "options": "total_cost"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "avg_latency"}, "properties": [{"id": "unit", "value": "ms"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 7,
      "options": {"footer": {"show": false}, "showHeader": true},
      "title": "Model Performance Comparison",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
          "rawSql": "SELECT model_used AS model, COUNT(*) AS total_runs, ROUND(100.0 * SUM(CASE WHEN success=1 THEN 1 ELSE 0 END) / COUNT(*), 1) AS success_rate, ROUND(AVG(latency_ms)) AS avg_latency, ROUND(SUM(cost_usd), 4) AS total_cost, SUM(tokens_input + tokens_output) AS total_tokens FROM pandora_agent_runs WHERE created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY model_used ORDER BY total_runs DESC",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["pandora", "ai", "devlake"],
  "templating": {
    "list": [
      {
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "definition": "SELECT DISTINCT project_id FROM pandora_agent_runs ORDER BY project_id",
        "hide": 0,
        "includeAll": true,
        "label": "Project",
        "name": "project",
        "options": [],
        "query": "SELECT DISTINCT project_id FROM pandora_agent_runs ORDER BY project_id",
        "refresh": 2,
        "type": "query"
      },
      {
        "datasource": {"type": "mysql", "uid": "devlake-mysql-ds"},
        "definition": "SELECT DISTINCT model_used FROM pandora_agent_runs ORDER BY model_used",
        "hide": 0,
        "includeAll": true,
        "label": "Model",
        "name": "model",
        "options": [],
        "query": "SELECT DISTINCT model_used FROM pandora_agent_runs ORDER BY model_used",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Pandora — AI Dev Overview",
  "uid": "pandora-ai-overview",
  "version": 1
}
